# === Paul McChatney — .gitignore ===
# Regla: el repo versiona TEXTO (prompts, letras, configs). La media (audio, vídeo,
# imágenes) se queda fuera. No hay que mantener esto carpeta por carpeta.

# --- Media / binarios: nunca a git ---
*.wav
*.mp3
*.flac
*.aif
*.aiff
*.m4a
*.ogg
*.mp4
*.mov
*.png
*.jpg
*.jpeg
*.zip

# --- proyectos: solo .md ---
proyectos/**
!proyectos/**/
!proyectos/**/*.md

# --- binarios de produccion (instaladores de plugins) ---
_produccion/plugins_angie/

# --- temporales / sistema ---
_temp/
_docs/
.DS_Store
Thumbs.db
_produccion/temporal_produccion/
